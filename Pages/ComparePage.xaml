<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AmedasArchiveWindows.Pages.ComparePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AmedasArchiveWindows.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="24" Spacing="20">

            <!-- ヘッダーセクション -->
            <StackPanel Spacing="4">
                <TextBlock Text="地域気候比較" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock Text="同期済み2地点の気象統計データを重ね合わせて視覚的に比較解析（民間API完全排除・ローカルDB処理）" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- 1. 比較対象地点の選択（左右2列） -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 地点A (基準地) -->
                <Border Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="📍 比較地点 A (基準地)" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="PrefectureAComboBox" Grid.Column="0" Header="都道府県" HorizontalAlignment="Stretch" SelectionChanged="PrefectureAComboBox_SelectionChanged" PlaceholderText="選択..."/>
                            <ComboBox x:Name="StationAComboBox" Grid.Column="1" Header="観測所" HorizontalAlignment="Stretch" SelectionChanged="StationAComboBox_SelectionChanged" PlaceholderText="選択..." IsEnabled="False"/>
                        </Grid>

                        <TextBlock x:Name="DateRangeATextBlock" Text="DBデータ期間: 未取得" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- 地点B (比較地) -->
                <Border Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="📍 比較地点 B (比較地)" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" Foreground="#FFE91E63"/>
                        
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="PrefectureBComboBox" Grid.Column="0" Header="都道府県" HorizontalAlignment="Stretch" SelectionChanged="PrefectureBComboBox_SelectionChanged" PlaceholderText="選択..."/>
                            <ComboBox x:Name="StationBComboBox" Grid.Column="1" Header="観測所" HorizontalAlignment="Stretch" SelectionChanged="StationBComboBox_SelectionChanged" PlaceholderText="選択..." IsEnabled="False"/>
                        </Grid>

                        <TextBlock x:Name="DateRangeBTextBlock" Text="DBデータ期間: 未取得" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 2. 比較設定（期間、比較項目） -->
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock Text="⚙️ 比較設定" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 開始日 -->
                        <TextBox x:Name="StartDateTextBox" Grid.Column="0" Header="比較開始日 (YYYY-MM-DD)" PlaceholderText="例: 2025-01-01"/>
                        <!-- 終了日 -->
                        <TextBox x:Name="EndDateTextBox" Grid.Column="1" Header="比較終了日 (YYYY-MM-DD)" PlaceholderText="例: 2025-12-31"/>
                        <!-- 比較項目 -->
                        <ComboBox x:Name="CompareTypeComboBox" Grid.Column="2" Header="可視化グラフ対象" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="平均気温 (℃)" IsSelected="True"/>
                            <ComboBoxItem Content="最高気温 (℃)"/>
                            <ComboBoxItem Content="最低気温 (℃)"/>
                            <ComboBoxItem Content="降水量 (mm)"/>
                        </ComboBox>
                    </Grid>

                    <TextBlock x:Name="CommonRangeTextBlock" Text="共通データ期間: 自動判定待ち" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock x:Name="ErrorTextBlock" Text="" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Bold" Visibility="Collapsed"/>

                    <Button x:Name="CompareButton" Content="2地点の気象データを比較する" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10,0,10" Click="CompareButton_Click"/>
                </StackPanel>
            </Border>

            <!-- 3. 比較結果（計算成功時に表示） -->
            <StackPanel x:Name="ResultPanel" Spacing="20" Visibility="Collapsed">
                
                <!-- 美麗なカスタムグラフカード -->
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="20">
                    <StackPanel Spacing="12">
                        <Grid>
                            <TextBlock x:Name="GraphTitleTextBlock" Text="📈 気温推移比較" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                            <!-- 凡例 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="16" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="12" Height="12" Fill="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    <TextBlock x:Name="LegendATextBlock" Text="地点A" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="12" Height="12" Fill="#FFE91E63"/>
                                    <TextBlock x:Name="LegendBTextBlock" Text="地点B" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- グラフ描画キャンバス領域 -->
                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Height="280" Margin="0,8,0,8" Padding="8">
                            <Grid>
                                <!-- 背景目盛りグリッド用 Canvas -->
                                <Canvas x:Name="GridCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                <!-- グラフ線描画用 Canvas -->
                                <Canvas x:Name="ChartCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" SizeChanged="ChartCanvas_SizeChanged"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 総合統計対比表 -->
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="📊 期間中の気候統計対比" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                        
                        <Grid ColumnSpacing="16" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 表ヘッダー -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="比較指標" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
                            <Border Grid.Row="0" Grid.Column="1" Background="{ThemeResource AccentTextFillColorPrimaryBrush}" Opacity="0.1" CornerRadius="4" Padding="6,4">
                                <TextBlock x:Name="HeaderATextBlock" Text="地点 A" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="0" Grid.Column="2" Background="#FFE91E63" Opacity="0.1" CornerRadius="4" Padding="6,4">
                                <TextBlock x:Name="HeaderBTextBlock" Text="地点 B" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="#FFE91E63" HorizontalAlignment="Center"/>
                            </Border>

                            <!-- 1. 平均気温 -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="平均気温" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="MeanTempATextBlock" Grid.Row="1" Grid.Column="1" Text="-- ℃" Style="{StaticResource BodyStrongTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="MeanTempBTextBlock" Grid.Row="1" Grid.Column="2" Text="-- ℃" Style="{StaticResource BodyStrongTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- 2. 最高気温（期間内極値） -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="最高気温（極値）" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="MaxTempATextBlock" Grid.Row="2" Grid.Column="1" Text="-- ℃" Style="{StaticResource BodyTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="MaxTempBTextBlock" Grid.Row="2" Grid.Column="2" Text="-- ℃" Style="{StaticResource BodyTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- 3. 最低気温（期間内極値） -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="最低気温（極値）" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="MinTempATextBlock" Grid.Row="3" Grid.Column="1" Text="-- ℃" Style="{StaticResource BodyTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="MinTempBTextBlock" Grid.Row="3" Grid.Column="2" Text="-- ℃" Style="{StaticResource BodyTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- 4. 総降水量 -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="総降水量" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalPrecipATextBlock" Grid.Row="4" Grid.Column="1" Text="-- mm" Style="{StaticResource BodyStrongTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalPrecipBTextBlock" Grid.Row="4" Grid.Column="2" Text="-- mm" Style="{StaticResource BodyStrongTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- 5. 晴天日数 -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="晴天率 (日照≧3h)" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SunnyRatioATextBlock" Grid.Row="5" Grid.Column="1" Text="-- %" Style="{StaticResource BodyTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SunnyRatioBTextBlock" Grid.Row="5" Grid.Column="2" Text="-- %" Style="{StaticResource BodyTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- 6. 降水日数 -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="降水日数 (雨量≧1mm)" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RainRatioATextBlock" Grid.Row="6" Grid.Column="1" Text="-- %" Style="{StaticResource BodyTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RainRatioBTextBlock" Grid.Row="6" Grid.Column="2" Text="-- %" Style="{StaticResource BodyTextBlockStyle}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
            </StackPanel>

            <!-- 免責バナー -->
            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="法的特記事項および免責事項"
                Message="本比較結果は、ローカルDB内に同期されている過去気象庁CSVデータを基に独自に集計・グラフ化したものであり、気象予報業務（将来の天候の決定・予測）や公式な気象観測証明を行うものではありません。データソース: 気象庁ホームページ (https://www.jma.go.jp/)"
                Margin="0,12,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Page>
