<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AmedasArchiveWindows.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AmedasArchiveWindows.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="24" Spacing="20">
            
            <!-- ヘッダーセクション -->
            <StackPanel Spacing="4">
                <TextBlock Text="AMEDAS 過去統計アーカイブ" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock Text="民間API完全排除・ローカルDB算出型気候統計エンジン" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- 1. 地域・観測所選択カード -->
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="1. 地域・観測所（アメダス）選択" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                    
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="PrefectureComboBox" Grid.Column="0" Header="都道府県" HorizontalAlignment="Stretch" SelectionChanged="PrefectureComboBox_SelectionChanged" PlaceholderText="選択してください"/>
                        <ComboBox x:Name="StationComboBox" Grid.Column="1" Header="観測所" HorizontalAlignment="Stretch" SelectionChanged="StationComboBox_SelectionChanged" PlaceholderText="選択してください" IsEnabled="False"/>
                    </Grid>

                    <!-- データ期間の自動検知表示 -->
                    <TextBlock x:Name="DateRangeTextBlock" Text="DBデータ期間: 未取得" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- 2. 統計日及び検証年指定カード -->
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock Text="2. 統計日及び検証年指定" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="YearTextBox" Grid.Column="0" Header="検証対象年" PlaceholderText="例: 2026"/>
                        <TextBox x:Name="MonthTextBox" Grid.Column="1" Header="月" PlaceholderText="1-12"/>
                        <TextBox x:Name="DayTextBox" Grid.Column="2" Header="日" PlaceholderText="1-31"/>
                    </Grid>

                    <TextBlock x:Name="ErrorTextBlock" Text="" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Bold" Visibility="Collapsed"/>

                    <Button x:Name="CalculateButton" Content="過去統計データを算出する" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10,0,10" Click="CalculateButton_Click"/>
                </StackPanel>
            </Border>

            <!-- 3. 統計結果カード（計算成功時に表示） -->
            <Border x:Name="ResultCard" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="20" Visibility="Collapsed">
                <StackPanel Spacing="16">
                    <TextBlock x:Name="ResultTitleTextBlock" Text="📊 東京 - 07月07日の過去30年間統計" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>

                    <Grid Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 晴天確率 -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="晴れの確率" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="SunnyProbabilityTextBlock" Text="85.5%" FontSize="32" FontWeight="Black" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- 降水確率 -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="降水確率 (>=1.0mm)" Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="RainProbabilityTextBlock" Text="14.5%" FontSize="32" FontWeight="Black" Foreground="#FFE91E63" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <MenuFlyoutSeparator />

                    <!-- 気温平均データ -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="気温統計平均" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="8" CornerRadius="4">
                                <TextBlock Text="平均気温" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="TempMeanTextBlock" Text="26.5 ℃" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="8" CornerRadius="4">
                                <TextBlock Text="最高気温" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="TempMaxTextBlock" Text="30.2 ℃" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="8" CornerRadius="4">
                                <TextBlock Text="最低気温" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="TempMinTextBlock" Text="22.1 ℃" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 法的遵守事項＆免責バナーを下部に常時表示 -->
            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="法的特記事項および免責事項"
                Message="本アプリに掲載されている統計・解析結果は、すべて気象庁の過去公開データからローカル環境において独自に算出されたものであり、将来の予報や公式気象業務（予報・警告など）を行うものではありません。気象業務法により予報業務等の対象外として適切に設計されています。二次利用についてはクリエイティブ・コモンズ・ライセンス（CC BY 4.0）に基づき提供されています。データソース: 気象庁ホームページ (https://www.jma.go.jp/)"
                Margin="0,12,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Page>
