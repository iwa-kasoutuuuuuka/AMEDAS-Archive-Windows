<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AmedasArchiveWindows.Pages.SingularityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AmedasArchiveWindows.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="24" Spacing="20">

            <!-- ヘッダーセクション -->
            <StackPanel Spacing="4">
                <TextBlock Text="特異日スキャン分析" Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock Text="ローカル蓄積データから統計的に極端な天候を示す特定日を抽出します" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- 観測地点および解析タイプ選択カード -->
            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock Text="分析パラメータ設定" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- 地点選択 (二段階ComboBox) -->
                        <ComboBox x:Name="PrefectureComboBox" Grid.Row="0" Grid.Column="0" Header="都道府県" HorizontalAlignment="Stretch" SelectionChanged="PrefectureComboBox_SelectionChanged" PlaceholderText="選択してください"/>
                        <ComboBox x:Name="StationComboBox" Grid.Row="0" Grid.Column="1" Header="観測所" HorizontalAlignment="Stretch" SelectionChanged="StationComboBox_SelectionChanged" PlaceholderText="選択してください" IsEnabled="False"/>

                        <!-- 解析タイプ選択 -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="8" Margin="0,4,0,0">
                            <TextBlock Text="解析する特異日タイプ" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <RadioButton x:Name="SunnyRadioButton" Content="晴天特異日 (晴れやすさ重視)" IsChecked="True" GroupName="TypeGroup"/>
                                <RadioButton x:Name="RainyRadioButton" Content="雨天特異日 (降水頻度重視)" GroupName="TypeGroup"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="ErrorTextBlock" Text="" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Bold" Visibility="Collapsed"/>

                    <Button x:Name="AnalyzeButton" Content="特異日スキャン分析を実行する" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10,0,10" Click="AnalyzeButton_Click"/>
                </StackPanel>
            </Border>

            <!-- スキャン実行中ローディング表示 -->
            <StackPanel x:Name="LoadingPanel" Spacing="12" Padding="20" HorizontalAlignment="Center" Visibility="Collapsed">
                <ProgressRing IsActive="True" Width="40" Height="40" />
                <TextBlock Text="365日の気象実績データをローカル走査中..." Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- 分析結果ランキングセクション（計算成功時に表示） -->
            <StackPanel x:Name="ResultSection" Spacing="12" Visibility="Collapsed">
                <TextBlock x:Name="ResultHeaderTextBlock" Text="🏆 晴天特異日 Top 5 ランキング" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>

                <ListView x:Name="ResultListView" SelectionMode="None" ItemContainerTransitions="{x:Null}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Margin="0,4,0,4" Padding="12" HorizontalAlignment="Stretch">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="1.5*" />
                                        <ColumnDefinition Width="1.5*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 順位バッジ -->
                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{ThemeResource AccentBrush}" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Rank}" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- 月日 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding MonthDayString}" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="18"/>
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <!-- 晴天率 -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="晴天確率" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SunProbabilityString}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    </StackPanel>

                                    <!-- 降雨率 -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Text="降水確率" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{Binding RainProbabilityString}" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="#FFE91E63"/>
                                    </StackPanel>

                                    <!-- 平均気温 -->
                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" MinWidth="80">
                                        <TextBlock Text="平均気温" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{Binding AvgTempString}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- 法的遵守事項＆免責バナー -->
            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="データ分析および特異日定義について"
                Message="特異日（Singularity）とは、その前後の日に比べて偶然とは思えないほど高い確率で特定の気象状態（晴れ、雨等）が発生する特定の日のことです。本分析機能は、ローカルDB内に蓄積された過去データのみから純粋に統計抽出を行ったローカル演算値です。データソース: 気象庁ホームページ (https://www.jma.go.jp/)"
                Margin="0,12,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Page>

